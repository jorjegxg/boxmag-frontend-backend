{
  "name": "boxmag-backend",
  "version": "1.0.0",
  "description": "Boxmag backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "db:reset": "bash ./db/reset_and_seed.sh",
    "db:seed:images": "node ./db/seed_minio_images.js"
  },
  "keywords": [],
  "author": "Boxmag",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "mysql2": "^3.15.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
