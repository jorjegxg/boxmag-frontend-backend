## Copy to `.env.mysql` in this folder (boxmagApp) and customize
## Used by boxmag4/docker-compose.yml via: ../.env.mysql

# Host port -> container 3306
MYSQL_PORT=3306

# MySQL credentials & default DB
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=boxmag4
MYSQL_USER=boxmag4
MYSQL_PASSWORD=change-me-user

TZ=UTC

